# ═══════════════════════════════════════════════════════════════
#  OCTOPUS — Variables de Entorno (Backend Django)
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA commites el .env — ya está en .gitignore.
# ═══════════════════════════════════════════════════════════════

# ── Django Core ───────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga

# True solo en desarrollo local, NUNCA en producción
DJANGO_DEBUG=True

# Hosts permitidos separados por coma o espacio
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS y CSRF ───────────────────────────────────────────────
# Dominios adicionales del frontend (separados por espacio).
# localhost:5173 ya está incluido por defecto en settings.py.
# En producción agregar: https://app.micolegio.edu.ve https://portal.micolegio.edu.ve
DJANGO_CORS_ORIGINS=http://localhost:5173
DJANGO_CSRF_ORIGINS=http://localhost:5173

# ── Email SMTP ────────────────────────────────────────────────
# Desarrollo: django.core.mail.backends.console.EmailBackend  (imprime en terminal)
# Producción: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@tucolegio.edu
# Para Gmail usar "contraseña de aplicación", no la contraseña normal de la cuenta
EMAIL_HOST_PASSWORD=

# ── Portal de Representantes ──────────────────────────────────
# Remitente que aparece en los correos enviados desde el portal
PORTAL_EMAIL_FROM=noreply@tucolegio.edu
# Email del director que recibe la alerta de mora en el día 15
# Si se deja vacío, settings.py emite un RuntimeWarning al arrancar
PORTAL_EMAIL_DIRECTOR=director@tucolegio.edu

# ── Celery + Redis ────────────────────────────────────────────
# Redis debe estar corriendo localmente: https://redis.io/download
# En producción usar una instancia Redis administrada (ElastiCache, Redis Cloud, etc.)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Stripe (Pagos en línea desde el portal) ───────────────────
# Obtener credenciales en: https://dashboard.stripe.com/apikeys
# Usar claves de TEST (sk_test_ / pk_test_) para desarrollo
# Usar claves LIVE (sk_live_ / pk_live_) solo en producción
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── URL del Frontend ──────────────────────────────────────────
# Usada para construir enlaces en emails (ej. "Ver factura en el portal")
FRONTEND_URL=http://localhost:5173

# ── Variables comentadas: WhatsApp (implementación futura) ────
# Descomentar cuando se integre Twilio o Meta Business API
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# PORTAL_DIRECTOR_WHATSAPP=whatsapp:+58412xxxxxxx
