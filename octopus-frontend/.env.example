# ═══════════════════════════════════════════════════════════════
#  OCTOPUS Frontend — Variables de Entorno
#  Copia como .env (desarrollo) o .env.production (producción)
#  NUNCA commites el .env — ya está en .gitignore.
# ═══════════════════════════════════════════════════════════════

# URL base del API Django (sin / al final)
# Desarrollo: http://127.0.0.1:8000
# Producción: https://api.tucolegio.edu
VITE_API_BASE_URL=http://127.0.0.1:8000

# Stripe publishable key (pública, segura para exponer en el frontend)
# Usar pk_test_... para desarrollo, pk_live_... para producción
# Obtener en: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
